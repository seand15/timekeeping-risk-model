    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "N_EMPLOYEES = 500\n",
    "N_MANAGERS = 40\n",
    "\n",
    "DEPARTMENTS = [\"Warehouse\", \"Fulfillment\", \"Retail Ops\", \"Support\"]\n",
    "LOCATIONS = [\"Los Angeles\", \"San Diego\", \"Sacramento\"]\n",
    "SHIFT_TYPES = [\"Morning\", \"Day\", \"Evening\"]\n",
    "\n",
    "MANAGER_TYPES = [\"stable\", \"ot_heavy\", \"break_weak\", \"chaotic\"]\n",
    "MANAGER_TYPE_PROBS = [0.40, 0.20, 0.20, 0.20]\n",
    "\n",
    "SHIFT_TYPE_PROBS = [0.35, 0.45, 0.20]\n",
    "\n",
    "MIN_HOURLY_RATE = 18\n",
    "MAX_HOURLY_RATE = 35\n",
    "\n",
    "MIN_TENURE_DAYS = 30\n",
    "MAX_TENURE_DAYS = 2500\n",
    "\n",
    "manager_ids = [f\"M{str(i).zfill(3)}\" for i in range(1, N_MANAGERS + 1)]\n",
    "\n",
    "manager_df = pd.DataFrame({\n",
    "    \"manager_id\": manager_ids,\n",
    "    \"manager_type\": np.random.choice(\n",
    "        MANAGER_TYPES,\n",
    "        size=N_MANAGERS,\n",
    "        p=MANAGER_TYPE_PROBS\n",
    "    ),\n",
    "    \"department\": np.random.choice(DEPARTMENTS, size=N_MANAGERS),\n",
    "    \"location\": np.random.choice(LOCATIONS, size=N_MANAGERS)\n",
    "})\n",
    "\n",
    "employee_ids = [f\"E{str(i).zfill(4)}\" for i in range(1, N_EMPLOYEES + 1)]\n",
    "\n",
    "assigned_manager_ids = np.random.choice(manager_df[\"manager_id\"], size=N_EMPLOYEES)\n",
    "\n",
    "employee_df = pd.DataFrame({\n",
    "    \"employee_id\": employee_ids,\n",
    "    \"manager_id\": assigned_manager_ids,\n",
    "    \"shift_type\": np.random.choice(\n",
    "        SHIFT_TYPES,\n",
    "        size=N_EMPLOYEES,\n",
    "        p=SHIFT_TYPE_PROBS\n",
    "    ),\n",
    "    \"hourly_rate\": np.round(\n",
    "        np.random.uniform(MIN_HOURLY_RATE, MAX_HOURLY_RATE, size=N_EMPLOYEES),\n",
    "        2\n",
    "    ),\n",
    "    \"tenure_days\": np.random.randint(\n",
    "        MIN_TENURE_DAYS,\n",
    "        MAX_TENURE_DAYS + 1,\n",
    "        size=N_EMPLOYEES\n",
    "    )\n",
    "})\n",
    "\n",
    "employee_df = employee_df.merge(\n",
    "    manager_df[[\"manager_id\", \"department\", \"location\"]],\n",
    "    on=\"manager_id\",\n",
    "    how=\"left\"\n",
    ")\n",
    "\n",
    "employee_df = employee_df[\n",
    "    [\"employee_id\", \"manager_id\", \"department\", \"location\", \"shift_type\", \"hourly_rate\", \"tenure_days\"]\n",
    "]\n",
    "\n",
    "print(\"Manager table shape:\", manager_df.shape)\n",
    "print(\"Employee table shape:\", employee_df.shape)\n",
    "\n",
    "print(\"\\n--- Manager Sample ---\")\n",
    "print(manager_df.head())\n",
    "\n",
    "print(\"\\n--- Employee Sample ---\")\n",
    "print(employee_df.head())\n",
    "\n",
    "print(\"\\n--- Manager Type Distribution ---\")\n",
    "print(manager_df[\"manager_type\"].value_counts(normalize=True).round(3))\n",
    "\n",
    "print(\"\\n--- Shift Type Distribution ---\")\n",
    "print(employee_df[\"shift_type\"].value_counts(normalize=True).round(3))\n",
    "\n",
    "print(\"\\n--- Employees per Manager Summary ---\")\n",
    "print(employee_df[\"manager_id\"].value_counts().describe().round(2))"
