    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "N_DAYS = 180\n",
    "START_DATE = \"2025-01-01\"\n",
    "\n",
    "WORKDAY_PROBS = {\n",
    "    0: 0.92,  # Monday\n",
    "    1: 0.95,  # Tuesday\n",
    "    2: 0.95,  # Wednesday\n",
    "    3: 0.95,  # Thursday\n",
    "    4: 0.90,  # Friday\n",
    "    5: 0.12,  # Saturday\n",
    "    6: 0.08   # Sunday\n",
    "}\n",
    "\n",
    "SHIFT_WINDOWS = {\n",
    "    \"Morning\": (6, 8),\n",
    "    \"Day\": (8, 10),\n",
    "    \"Evening\": (13, 15)\n",
    "}\n",
    "\n",
    "SHIFT_LENGTH_OPTIONS = [6, 7, 8, 9, 10]\n",
    "SHIFT_LENGTH_PROBS = [0.10, 0.15, 0.45, 0.20, 0.10]\n",
    "\n",
    "date_range = pd.date_range(start=START_DATE, periods=N_DAYS, freq=\"D\")\n",
    "date_df = pd.DataFrame({\"work_date\": date_range})\n",
    "date_df[\"day_of_week\"] = date_df[\"work_date\"].dt.dayofweek\n",
    "\n",
    "employee_df[\"_tmp_key\"] = 1\n",
    "date_df[\"_tmp_key\"] = 1\n",
    "\n",
    "schedule_df = employee_df.merge(date_df, on=\"_tmp_key\", how=\"outer\").drop(columns=\"_tmp_key\")\n",
    "\n",
    "schedule_df[\"work_probability\"] = schedule_df[\"day_of_week\"].map(WORKDAY_PROBS)\n",
    "schedule_df[\"is_scheduled\"] = np.random.rand(len(schedule_df)) < schedule_df[\"work_probability\"]\n",
    "\n",
    "schedule_df = schedule_df[schedule_df[\"is_scheduled\"]].copy()\n",
    "\n",
    "def generate_start_hour(shift_type):\n",
    "    low, high = SHIFT_WINDOWS[shift_type]\n",
    "    return np.random.randint(low, high + 1)\n",
    "\n",
    "def generate_start_minute():\n",
    "    return np.random.choice([0, 15, 30, 45], p=[0.35, 0.20, 0.30, 0.15])\n",
    "\n",
    "schedule_df[\"scheduled_start_hour\"] = schedule_df[\"shift_type\"].apply(generate_start_hour)\n",
    "schedule_df[\"scheduled_start_minute\"] = [generate_start_minute() for _ in range(len(schedule_df))]\n",
    "\n",
    "schedule_df[\"scheduled_start\"] = (\n",
    "    schedule_df[\"work_date\"]\n",
    "    + pd.to_timedelta(schedule_df[\"scheduled_start_hour\"], unit=\"h\")\n",
    "    + pd.to_timedelta(schedule_df[\"scheduled_start_minute\"], unit=\"m\")\n",
    ")\n",
    "\n",
    "schedule_df[\"scheduled_shift_hours\"] = np.random.choice(\n",
    "    SHIFT_LENGTH_OPTIONS,\n",
    "    size=len(schedule_df),\n",
    "    p=SHIFT_LENGTH_PROBS\n",
    ")\n",
    "\n",
    "schedule_df[\"scheduled_end\"] = (\n",
    "    schedule_df[\"scheduled_start\"]\n",
    "    + pd.to_timedelta(schedule_df[\"scheduled_shift_hours\"], unit=\"h\")\n",
    ")\n",
    "\n",
    "schedule_df[\"scheduled_break_minutes\"] = np.where(\n",
    "    schedule_df[\"scheduled_shift_hours\"] > 5,\n",
    "    30,\n",
    "    0\n",
    ")\n",
    "\n",
    "schedule_df = schedule_df[\n",
    "    [\n",
    "        \"employee_id\",\n",
    "        \"manager_id\",\n",
    "        \"department\",\n",
    "        \"location\",\n",
    "        \"shift_type\",\n",
    "        \"hourly_rate\",\n",
    "        \"tenure_days\",\n",
    "        \"work_date\",\n",
    "        \"scheduled_start\",\n",
    "        \"scheduled_end\",\n",
    "        \"scheduled_break_minutes\"\n",
    "    ]\n",
    "].sort_values([\"employee_id\", \"work_date\"]).reset_index(drop=True)\n",
    "\n",
    "print(\"Schedule table shape:\", schedule_df.shape)\n",
    "\n",
    "print(\"\\n--- Schedule Sample ---\")\n",
    "print(schedule_df.head())\n",
    "\n",
    "print(\"\\n--- Scheduled Days per Employee Summary ---\")\n",
    "print(schedule_df[\"employee_id\"].value_counts().describe().round(2))\n",
    "\n",
    "schedule_df[\"scheduled_shift_hours_check\"] = (\n",
    "    (schedule_df[\"scheduled_end\"] - schedule_df[\"scheduled_start\"]).dt.total_seconds() / 3600\n",
    ")\n",
    "\n",
    "print(\"\\n--- Shift Length Distribution ---\")\n",
    "print(schedule_df[\"scheduled_shift_hours_check\"].value_counts().sort_index())\n",
    "\n",
    "print(\"\\n--- Break Minutes Distribution ---\")\n",
    "\n",
    "schedule_df.drop(columns=\"scheduled_shift_hours_check\", inplace=True)"
   ]
