    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "np.random.seed(42)\n",
    "\n",
    "behavior_df = schedule_df.copy()\n",
    "\n",
    "behavior_df = behavior_df.merge(\n",
    "    manager_df[[\"manager_id\", \"manager_type\"]],\n",
    "    on=\"manager_id\",\n",
    "    how=\"left\"\n",
    ")\n",
    "\n",
    "VIOLATION_PROBS = {\n",
    "    \"stable\": 0.15,\n",
    "    \"ot_heavy\": 0.20,\n",
    "    \"break_weak\": 0.32,\n",
    "    \"chaotic\": 0.24\n",
    "}\n",
    "\n",
    "MISSED_MEAL_PROBS = {\n",
    "    \"stable\": 0.012,\n",
    "    \"ot_heavy\": 0.045,\n",
    "    \"break_weak\": 0.070,\n",
    "    \"chaotic\": 0.060\n",
    "}\n",
    "\n",
    "def sample_clock_in_offset(manager_type):\n",
    "    \"\"\"\n",
    "    Minutes relative to scheduled_start.\n",
    "    Negative = early, Positive = late\n",
    "    \"\"\"\n",
    "    if manager_type == \"stable\":\n",
    "        return int(np.clip(np.random.normal(loc=-2, scale=5), -20, 20))\n",
    "    elif manager_type == \"ot_heavy\":\n",
    "        return int(np.clip(np.random.normal(loc=-4, scale=6), -25, 20))\n",
    "    elif manager_type == \"break_weak\":\n",
    "        return int(np.clip(np.random.normal(loc=-2, scale=6), -20, 20))\n",
    "    elif manager_type == \"chaotic\":\n",
    "        return int(np.clip(np.random.normal(loc=0, scale=10), -30, 30))\n",
    "    return int(np.clip(np.random.normal(loc=0, scale=6), -20, 20))\n",
    "\n",
    "\n",
    "def sample_clock_out_offset(manager_type):\n",
    "    \"\"\"\n",
    "    Minutes relative to scheduled_end.\n",
    "    Positive = staying late, Negative = leaving early\n",
    "    \"\"\"\n",
    "    if manager_type == \"stable\":\n",
    "        return int(np.clip(np.random.normal(loc=3, scale=10), -25, 35))\n",
    "    elif manager_type == \"ot_heavy\":\n",
    "        return int(np.clip(np.random.normal(loc=18, scale=15), -10, 75))\n",
    "    elif manager_type == \"break_weak\":\n",
    "        return int(np.clip(np.random.normal(loc=8, scale=12), -15, 45))\n",
    "    elif manager_type == \"chaotic\":\n",
    "        return int(np.clip(np.random.normal(loc=6, scale=20), -35, 60))\n",
    "    return int(np.clip(np.random.normal(loc=5, scale=12), -20, 40))\n",
    "\n",
    "\n",
    "def sample_break_start_fraction(manager_type):\n",
    "    violation = np.random.rand() < VIOLATION_PROBS[manager_type]\n",
    "\n",
    "    if violation:\n",
    "        return float(np.clip(np.random.normal(loc=0.65, scale=0.1), 0.4, 0.95))\n",
    "    else:\n",
    "        return float(np.clip(np.random.normal(loc=0.45, scale=0.05), 0.2, 0.7))\n",
    "\n",
    "\n",
    "def sample_break_minutes(manager_type, scheduled_break_minutes):\n",
    "    if scheduled_break_minutes == 0:\n",
    "        return 0\n",
    "\n",
    "    missed = np.random.rand() < MISSED_MEAL_PROBS[manager_type]\n",
    "    if missed:\n",
    "        return 0\n",
    "\n",
    "    violation = np.random.rand() < VIOLATION_PROBS[manager_type]\n",
    "\n",
    "    if violation:\n",
    "        return int(np.clip(np.random.normal(loc=22, scale=6), 1, 29))\n",
    "    else:\n",
    "        return int(np.clip(np.random.normal(loc=32, scale=2), 30, 40))\n",
    "\n",
    "def sample_manual_edit_flag(manager_type):\n",
    "    \"\"\"\n",
    "    More manual edits under chaotic managers.\n",
    "    \"\"\"\n",
    "    probs = {\n",
    "        \"stable\": 0.02,\n",
    "        \"ot_heavy\": 0.04,\n",
    "        \"break_weak\": 0.04,\n",
    "        \"chaotic\": 0.10\n",
    "    }\n",
    "    p = probs.get(manager_type, 0.04)\n",
    "    return int(np.random.rand() < p)\n",
    "\n",
    "clock_in_offsets = behavior_df[\"manager_type\"].apply(sample_clock_in_offset)\n",
    "clock_out_offsets = behavior_df[\"manager_type\"].apply(sample_clock_out_offset)\n",
    "\n",
